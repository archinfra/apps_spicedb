apiVersion: v1
kind: Namespace
metadata:
  name: __NAMESPACE__
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
---
apiVersion: v1
kind: Secret
metadata:
  name: spicedb-config
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
type: Opaque
data:
  grpc-preshared-key: __GRPC_PRESHARED_KEY_B64__
  datastore-conn-uri: __DATASTORE_CONN_URI_B64__
  postgres-admin-conn-uri: __POSTGRES_ADMIN_CONN_URI_B64__
  postgres-database: __POSTGRES_DATABASE_B64__
# __POSTGRES_CREATEDB_JOB_START__
---
apiVersion: batch/v1
kind: Job
metadata:
  name: spicedb-postgres-createdb
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
    app.kubernetes.io/component: postgres-createdb
spec:
  backoffLimit: 3
  template:
    metadata:
      labels:
        app.kubernetes.io/name: spicedb
        app.kubernetes.io/instance: spicedb
        app.kubernetes.io/component: postgres-createdb
    spec:
      restartPolicy: OnFailure
      containers:
      - name: postgres-createdb
        image: __POSTGRES_CLIENT_IMAGE__
        imagePullPolicy: __IMAGE_PULL_POLICY__
        command:
        - /bin/sh
        - -ec
        - |
          db="${SPICEDB_POSTGRES_DATABASE}"
          case "${db}" in
            ""|postgres|template0|template1)
              echo "invalid target database: ${db}" >&2
              exit 1
              ;;
            *[!A-Za-z0-9_-]*)
              echo "database name contains unsupported characters: ${db}" >&2
              exit 1
              ;;
          esac
          echo "checking postgres database: ${db}"
          exists="$(psql "${SPICEDB_POSTGRES_ADMIN_CONN_URI}" -v ON_ERROR_STOP=1 -tAc "SELECT 1 FROM pg_database WHERE datname='${db}'")"
          if [ "${exists}" = "1" ]; then
            echo "database already exists: ${db}"
          else
            echo "creating database: ${db}"
            psql "${SPICEDB_POSTGRES_ADMIN_CONN_URI}" -v ON_ERROR_STOP=1 -c "CREATE DATABASE \"${db}\""
          fi
        env:
        - name: SPICEDB_POSTGRES_ADMIN_CONN_URI
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: postgres-admin-conn-uri
        - name: SPICEDB_POSTGRES_DATABASE
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: postgres-database
# __POSTGRES_CREATEDB_JOB_END__
# __MIGRATION_JOB_START__
---
apiVersion: batch/v1
kind: Job
metadata:
  name: spicedb-migrate
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
    app.kubernetes.io/component: migrate
spec:
  backoffLimit: 3
  template:
    metadata:
      labels:
        app.kubernetes.io/name: spicedb
        app.kubernetes.io/instance: spicedb
        app.kubernetes.io/component: migrate
    spec:
      restartPolicy: OnFailure
# __POSTGRES_CREATEDB_JOB_START__
      initContainers:
      - name: wait-postgres-database
        image: __POSTGRES_CLIENT_IMAGE__
        imagePullPolicy: __IMAGE_PULL_POLICY__
        command:
        - /bin/sh
        - -ec
        - |
          db="${SPICEDB_POSTGRES_DATABASE}"
          echo "waiting for postgres database: ${db}"
          i=0
          until [ "$(psql "${SPICEDB_POSTGRES_ADMIN_CONN_URI}" -v ON_ERROR_STOP=1 -tAc "SELECT 1 FROM pg_database WHERE datname='${db}'" 2>/dev/null || true)" = "1" ]; do
            i=$((i + 1))
            if [ "${i}" -ge 150 ]; then
              echo "timed out waiting for postgres database: ${db}" >&2
              exit 1
            fi
            sleep 2
          done
        env:
        - name: SPICEDB_POSTGRES_ADMIN_CONN_URI
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: postgres-admin-conn-uri
        - name: SPICEDB_POSTGRES_DATABASE
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: postgres-database
# __POSTGRES_CREATEDB_JOB_END__
      containers:
      - name: spicedb-migrate
        image: __SPICEDB_IMAGE__
        imagePullPolicy: __IMAGE_PULL_POLICY__
        args:
        - datastore
        - migrate
        - head
        - --datastore-engine=__DATASTORE_ENGINE__
        - --datastore-conn-uri=$(SPICEDB_DATASTORE_CONN_URI)
        - --log-level=__LOG_LEVEL__
        env:
        - name: SPICEDB_DATASTORE_CONN_URI
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: datastore-conn-uri
# __MIGRATION_JOB_END__
---
apiVersion: v1
kind: Service
metadata:
  name: spicedb
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
spec:
  type: __SERVICE_TYPE__
  selector:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
    app.kubernetes.io/component: server
  ports:
  - name: grpc
    port: 50051
    targetPort: grpc
    protocol: TCP
__NODEPORT_GRPC_LINE__
  - name: http
    port: 8443
    targetPort: http
    protocol: TCP
__NODEPORT_HTTP_LINE__
  - name: metrics
    port: 9090
    targetPort: metrics
    protocol: TCP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: spicedb
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/instance: spicedb
    app.kubernetes.io/component: server
spec:
  replicas: __REPLICAS__
  selector:
    matchLabels:
      app.kubernetes.io/name: spicedb
      app.kubernetes.io/instance: spicedb
      app.kubernetes.io/component: server
  template:
    metadata:
      labels:
        app.kubernetes.io/name: spicedb
        app.kubernetes.io/instance: spicedb
        app.kubernetes.io/component: server
    spec:
      terminationGracePeriodSeconds: 30
      containers:
      - name: spicedb
        image: __SPICEDB_IMAGE__
        imagePullPolicy: __IMAGE_PULL_POLICY__
        args:
        - serve
        - --grpc-addr=:50051
        - --grpc-preshared-key=$(SPICEDB_GRPC_PRESHARED_KEY)
        - --http-enabled=__HTTP_ENABLED__
        - --http-addr=:8443
        - --metrics-enabled=true
        - --metrics-addr=:9090
        - --datastore-engine=__DATASTORE_ENGINE__
        - --datastore-conn-uri=$(SPICEDB_DATASTORE_CONN_URI)
        - --log-level=__LOG_LEVEL__
        - --skip-release-check=true
        ports:
        - name: grpc
          containerPort: 50051
          protocol: TCP
        - name: http
          containerPort: 8443
          protocol: TCP
        - name: metrics
          containerPort: 9090
          protocol: TCP
        env:
        - name: SPICEDB_GRPC_PRESHARED_KEY
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: grpc-preshared-key
        - name: SPICEDB_DATASTORE_CONN_URI
          valueFrom:
            secretKeyRef:
              name: spicedb-config
              key: datastore-conn-uri
        readinessProbe:
          tcpSocket:
            port: grpc
          initialDelaySeconds: 10
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 12
        livenessProbe:
          tcpSocket:
            port: grpc
          initialDelaySeconds: 30
          periodSeconds: 20
          timeoutSeconds: 5
          failureThreshold: 6
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            cpu: "2"
            memory: 2Gi
